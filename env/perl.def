# PeRL Singularity Container
# Base: CUDA 12.8 + cuDNN 9, Ubuntu 22.04
# Python: 3.11 (via deadsnakes PPA)
# Package manager: uv
# Virtual env: /opt/perl-env  ← created by env/setup_env.sh after build
#
# Build:
#   sudo /opt/singularity/3.11.1/bin/singularity build perl.sif env/perl.def
#
# Setup (run once after build):
#   singularity exec --nv --writable-tmpfs perl.sif bash env/setup_env.sh
#
# Run (interactive):
#   singularity shell --nv --bind /path/to/data:/data perl.sif
#
# Run (script):
#   singularity exec --nv --bind /path/to/data:/data perl.sif bash recipes/trl/openr1/dapo_lora.sh
#
# Recommended bind mounts:
#   --bind $HOME/.cache/huggingface:/root/.cache/huggingface   # HF model cache
#   --bind $HOME/.cache/wandb:/root/.cache/wandb               # W&B cache
#   --bind /path/to/PeRL:/workspace                            # repo itself

Bootstrap: docker
From: nvidia/cuda:12.8.0-cudnn-devel-ubuntu22.04

%labels
    Maintainer PeRL
    Description PeRL training environment (TRL + vLLM backend)
    CUDA 12.8
    cuDNN 9
    Python 3.11
    PyTorch 2.8.0
    vLLM 0.10.2

%files
    # Copy pinned requirements into the image
    env/requirements_hard.txt /opt/perl/requirements_hard.txt

%environment
    # CUDA
    export CUDA_HOME=/usr/local/cuda
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:/usr/local/cuda/extras/CUPTI/lib64:$LD_LIBRARY_PATH

    # uv and virtual env
    export UV_HOME=/opt/uv
    export PATH=/opt/uv:/opt/perl-env/bin:$PATH
    export VIRTUAL_ENV=/opt/perl-env

    # Suppress common warnings
    export TOKENIZERS_PARALLELISM=false
    export PYTHONDONTWRITEBYTECODE=1

    # HuggingFace cache (override at runtime with --bind if needed)
    export HF_HOME=/root/.cache/huggingface

    # NCCL tuning for multi-GPU
    export NCCL_DEBUG=WARN
    export NCCL_IB_DISABLE=0
    export NCCL_P2P_DISABLE=0

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive
    export HOME=/root
    export CUDA_HOME=/usr/local/cuda

    # -------------------------------------------------------------------------
    # 1. System packages
    # -------------------------------------------------------------------------
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        software-properties-common \
        ca-certificates \
        curl \
        wget \
        git \
        git-lfs \
        build-essential \
        ninja-build \
        libopenmpi-dev \
        openmpi-bin \
        libssl-dev \
        libbz2-dev \
        libffi-dev \
        lzma \
        liblzma-dev \
        libreadline-dev \
        libsqlite3-dev \
        zlib1g-dev

    # Python 3.11 via deadsnakes (Ubuntu 22.04 ships 3.10)
    add-apt-repository -y ppa:deadsnakes/ppa
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-dev \
        python3.11-venv \
        python3.11-distutils

    # Make python3.11 the default
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1
    update-alternatives --install /usr/bin/python  python  /usr/bin/python3.11 1

    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # -------------------------------------------------------------------------
    # 2. Install uv
    # -------------------------------------------------------------------------
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/opt/uv sh

%runscript
    # Default: drop into bash (override by passing a command)
    if [ $# -eq 0 ]; then
        exec /bin/bash
    else
        exec "$@"
